+    oklad.avans_naqdsiz !== "" &&
+    oklad.avans_naqd !== "" &&
+    oklad.tax_payer !== "" &&
+    oklad.cash_tax !== "" &&
+    Object.keys(okladLimitErrors).length === 0;
+  const isValid = scheme === "foiz" ? isFoizValid : isOkladValid;
+
+  const handleSave = () => {
+    setShowErrors(true);
+    if (!isValid || periodLocked) return;
